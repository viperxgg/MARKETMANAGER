# ─── REQUIRED — the app cannot function without these ──────────────────────
# DATABASE_URL: PostgreSQL connection string. Required for all persistence:
#   - WorkflowRun / ExecutionLog (audit trails)
#   - ApprovalItem (approval gate checks)
#   - Drafts, leads, memory, reports
# Without it, server actions return "db-missing" notices and nothing is saved.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Auth (NextAuth / Auth.js v5) — also required
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_ALLOWED_EMAILS="azzam.khalaf.swd23@gmail.com"

# ─── Recommended ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL=""                # exact deployment URL on Vercel
OWNER_EMAIL="azzam.khalaf.swd23@gmail.com"

# ─── OpenAI (text + image) ─────────────────────────────────────────────────
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_IMAGE_MODEL=""
IMAGE_GENERATION_MODEL=""
IMAGE_STORAGE_PROVIDER=""
IMAGE_STORAGE_BUCKET=""

# ─── Lead-source provider abstraction ──────────────────────────────────────
LEAD_SEARCH_PROVIDER=""
LEAD_SEARCH_API_KEY=""

# ─── Meta Graph (Facebook publishing) ──────────────────────────────────────
META_PAGE_ID=""
META_ACCESS_TOKEN=""

# ─── Feature flags ─────────────────────────────────────────────────────────
USE_AGENT_RUNTIME="false"
ENABLE_FACEBOOK="false"
ENABLE_EMAIL="false"
ENABLE_GITHUB="false"
ENABLE_VERCEL="false"
