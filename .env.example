# =============================================================================
# MarketManager — environment template.
# Copy to .env and fill with REAL values. Never commit .env (it's gitignored).
# Every value below is a placeholder; nothing here works as-is.
# =============================================================================

# ─── Database (Supabase) ───────────────────────────────────────────────────
# Pooled connection (used by the app at runtime).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma migrations only).
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── OpenAI (text + image) ─────────────────────────────────────────────────
OPENAI_API_KEY="sk-PLACEHOLDER"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_IMAGE_MODEL="gpt-image-1"
IMAGE_GENERATION_MODEL="gpt-image-1"
IMAGE_STORAGE_PROVIDER="cloudinary"
IMAGE_STORAGE_BUCKET="your-cloudinary-cloud-name"

# ─── Lead-source provider ──────────────────────────────────────────────────
# Supported values:
#   google         → Google Places API (preferred, structured business data)
#   google-places  → same as "google", explicit alias
#   manual-csv     → no live discovery; CSV import only
#   google-custom-search / serpapi / bing-web-search → reserved (not implemented)
#
# When LEAD_SEARCH_PROVIDER=google or google-places, LEAD_SEARCH_API_KEY must be
# a Google Cloud API key with "Places API (New)" enabled and billing on.
LEAD_SEARCH_PROVIDER="google"
LEAD_SEARCH_API_KEY="REPLACE_WITH_GOOGLE_PLACES_API_KEY"

# ─── Meta Graph (Facebook publishing) ──────────────────────────────────────
META_PAGE_ID="REPLACE_WITH_FB_PAGE_ID"
META_ACCESS_TOKEN="REPLACE_WITH_LONG_LIVED_PAGE_TOKEN"

# ─── Authentication (NextAuth / Auth.js v5) — REQUIRED ─────────────────────
# Generate AUTH_SECRET with:  openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_32_BYTE_BASE64_SECRET"
# Username + password auth (Credentials provider). Single operator only.
AUTH_USERNAME="owner"
AUTH_PASSWORD="REPLACE_WITH_A_STRONG_UNIQUE_PASSWORD"
AUTH_URL="http://localhost:3000"

# Identity used by the agent + workflow runtimes when persisting rows.
OWNER_EMAIL="owner@example.com"

# Feature flag — turn on the new agent runtime path inside actions.ts.
USE_AGENT_RUNTIME="false"

# ─── Integration layer (src/lib/integrations) ──────────────────────────────
# Each integration is OFF by default. Set to "true" to allow dispatch().
# ENABLE_OPENAI is implicit (driven by OPENAI_API_KEY presence).
ENABLE_FACEBOOK="false"
ENABLE_EMAIL="false"
ENABLE_GITHUB="false"
ENABLE_VERCEL="false"
ENABLE_LEADS="false"

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY="re_PLACEHOLDER"
RESEND_FROM="Your Company <hello@example.com>"

# ─── GitHub (PAT with repo scope; fine-grained PAT recommended) ────────────
GITHUB_TOKEN="github_pat_PLACEHOLDER"
GITHUB_REPO="owner/repo"

# ─── Vercel ────────────────────────────────────────────────────────────────
VERCEL_TOKEN="REPLACE_WITH_VERCEL_TOKEN"
VERCEL_PROJECT_ID="REPLACE_WITH_PROJECT_ID"
VERCEL_TEAM_ID=""

# ─── Webhooks (disabled until verified handlers are implemented) ───────────
# /api/webhooks/<provider> returns 501 in production-ready builds until provider
# verification and concrete handlers are implemented.
WEBHOOK_SECRET_META=""
WEBHOOK_SECRET_RESEND=""
WEBHOOK_SECRET_GITHUB=""
