# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM=""             # e.g. "Smart Art AI <hello@smartartai.se>"

# ─── GitHub ────────────────────────────────────────────────────────────────
